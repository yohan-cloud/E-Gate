{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListEventArchiveBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::egate-barangay663a-event-archive",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "events/*"
          ]
        }
      }
    },
    {
      "Sid": "ReadWriteEventArchiveObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:PutObjectTagging",
        "s3:GetObjectTagging"
      ],
      "Resource": "arn:aws:s3:::egate-barangay663a-event-archive/events/*"
    }
  ]
}
