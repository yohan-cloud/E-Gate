# Event archival to AWS S3
# Event archive payloads include event details, registrations, attendance, and entry log history.
EVENT_ARCHIVE_STORAGE_BACKEND=s3
EVENT_ARCHIVE_KEY_PREFIX=events
EVENT_ARCHIVE_S3_BUCKET=egate-barangay663a-event-archive
EVENT_ARCHIVE_S3_REGION=ap-southeast-2
EVENT_ARCHIVE_S3_ENDPOINT_URL=
EVENT_ARCHIVE_S3_STORAGE_CLASS=STANDARD
EVENT_ARCHIVE_S3_SSE=AES256
EVENT_ARCHIVE_S3_KMS_KEY_ID=
EVENT_ARCHIVE_S3_TAGS=archive_kind=event,project=egate,barangay=663-a
