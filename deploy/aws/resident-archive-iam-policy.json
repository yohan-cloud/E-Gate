{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListResidentArchiveBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::egate-barangay663a-resident-archive",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "resident_profiles/*"
          ]
        }
      }
    },
    {
      "Sid": "ReadWriteResidentArchiveObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:PutObjectTagging",
        "s3:GetObjectTagging"
      ],
      "Resource": "arn:aws:s3:::egate-barangay663a-resident-archive/resident_profiles/*"
    }
  ]
}
